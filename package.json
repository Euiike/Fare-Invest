{
  "name": "policy-calculator",
  "version": "1.0.0",
  "description": "投放策略计算器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.policy.calculator",
    "productName": "投放策略计算器",
    "win": {
      "target": "portable",
      "icon": null
    },
    "files": [
      "main.js",
      "index.html"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  }
}
